# App Settings
APP_NAME="ScannerNeuro IDX Breakout"
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/scanner_neuro"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Telegram
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id_here"

# Scanner Settings
SCAN_INTERVAL_MINUTES=5
RVOL_THRESHOLD=2.0
MIN_VOLUME=1000000
